{
  "$schema": "https://specialist-agent.dev/schemas/security-hooks-v1.json",
  "version": "1.0.0",
  "description": "Security rules for the native security-guard hook. Customize per-project.",
  "enabled": true,
  "rules": {
    "catastrophic-rm": { "enabled": true, "severity": "CRITICAL" },
    "fork-bomb": { "enabled": true, "severity": "CRITICAL" },
    "disk-wipe": { "enabled": true, "severity": "CRITICAL" },
    "force-push-protected": { "enabled": true, "severity": "HIGH" },
    "hard-reset": { "enabled": true, "severity": "HIGH" },
    "sql-destructive": { "enabled": true, "severity": "HIGH" },
    "pipe-to-shell": { "enabled": true, "severity": "HIGH" },
    "chmod-777": { "enabled": true, "severity": "HIGH" },
    "env-file-read": { "enabled": true, "severity": "MEDIUM" },
    "ssh-key-access": { "enabled": true, "severity": "MEDIUM" },
    "aws-credentials": { "enabled": true, "severity": "MEDIUM" },
    "cloud-credentials": { "enabled": true, "severity": "MEDIUM" },
    "env-file-write": { "enabled": true, "severity": "MEDIUM" },
    "inline-secrets": { "enabled": true, "severity": "MEDIUM" }
  },
  "allowlist": [
    "rm -rf node_modules",
    "rm -rf dist",
    "rm -rf build",
    "rm -rf .next",
    "rm -rf .nuxt",
    "rm -rf .svelte-kit",
    "rm -rf coverage",
    "rm -rf .turbo",
    "rm -rf .cache"
  ],
  "protectedBranches": ["main", "master", "production", "release"]
}
